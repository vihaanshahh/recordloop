# RecordLoop Configuration
# Copy to .env and edit as needed: cp .env.example .env
# Or run: python -m recordloop init

# Your frontend framework (auto-detected if blank)
# Options: react, next, vite, vue, nuxt, angular, svelte, gatsby, remix, astro
RECORDLOOP_FRAMEWORK=

# Dev server URL (auto-set from framework if blank)
RECORDLOOP_BASE_URL=http://localhost:3000
RECORDLOOP_PORT=3000

# Recording settings
RECORDLOOP_VIDEO_DIR=test-videos
RECORDLOOP_TEST_OUTPUT_DIR=generated-tests
RECORDLOOP_HEADLESS=true
RECORDLOOP_SLOW_MO=0

# Viewport
RECORDLOOP_VIEWPORT_WIDTH=1280
RECORDLOOP_VIEWPORT_HEIGHT=720
